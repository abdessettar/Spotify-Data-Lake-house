# .env.example
# Fill these after cloning the repo, then rename to .env and fill the values based on your account.
# This is being git ignored.
# ENVIRONMENT modes:
#   DEV   — Azurite emulator (for development/testing, requires docker compose up -d)
#   LOCAL — Real Azure Storage via `az login` (run at home, writes to Azure)
#   PROD  — Real Azure Storage via managed identity (Container Apps in Azure)
ENVIRONMENT='LOCAL'

# Spotify Credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID='your-client-id'
SPOTIFY_CLIENT_SECRET='your-client-secret'
SPOTIFY_REFRESH_TOKEN='your-refresh-token'

# Storage Config
AZURE_STORAGE_ACCOUNT = "stspotifydeprod"
DATA_CONTAINER = "spotify-data"

# Azure Identity (PROD only: set by Terraform/Container Apps)
# AZURE_CLIENT_ID = "your-managed-identity-client-id"
# KEY_VAULT_URI = "https://your-keyvault.vault.azure.net/"

# DEV mode only (Azurite emulator host)
# AZURITE_HOST = "127.0.0.1"
